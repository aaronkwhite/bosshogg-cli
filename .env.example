# BossHogg — local development env vars
# Copy to .env and fill in. .env is gitignored.

# --- Primary auth (personal API key; phx_ prefix) ---
POSTHOG_CLI_TOKEN=phx_your_personal_api_key_here

# --- Target project (dogfood target is 999999 on US Cloud) ---
POSTHOG_CLI_PROJECT_ID=999999
POSTHOG_CLI_ENV_ID=
POSTHOG_CLI_ORG_ID=
POSTHOG_CLI_HOST=https://us.posthog.com

# --- Test-suite gates ---
# Set to opt into live integration tests (tests/live.rs). Unset = tests skipped.
# BOSSHOGG_LIVE=1
# BOSSHOGG_RECORD_FIXTURES=1   # re-records wiremock fixtures from live API

# --- Tracing / debug ---
# BOSSHOGG_LOG=bosshogg=debug
