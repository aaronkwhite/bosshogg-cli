{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bosshogg://schema_hogql",
  "title": "bosshogg schema hogql --json",
  "type": "object",
  "required": ["tables"],
  "properties": {
    "posthog_version": { "type": ["string", "null"] },
    "project_id": { "type": ["integer", "null"] },
    "env_id": { "type": ["integer", "null"] },
    "tables": {
      "type": "array",
      "items": { "$ref": "#/$defs/table" }
    },
    "warehouse_tables": {
      "type": "array",
      "items": { "$ref": "#/$defs/table" }
    },
    "system_tables": {
      "type": "array",
      "items": { "$ref": "#/$defs/table" }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "table": {
      "type": "object",
      "required": ["name", "columns"],
      "properties": {
        "name": { "type": "string" },
        "kind": { "type": ["string", "null"] },
        "columns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "schema_valid": { "type": "boolean" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  }
}
