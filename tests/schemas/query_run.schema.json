{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bosshogg://query_run",
  "title": "bosshogg query run --json",
  "type": "object",
  "required": ["results", "columns", "types"],
  "properties": {
    "results": {
      "type": "array",
      "items": { "type": "array" }
    },
    "columns": { "type": "array", "items": { "type": "string" } },
    "types": { "type": "array", "items": { "type": ["array", "string"] } },
    "hogql": { "type": ["string", "null"] },
    "clickhouse": { "type": ["string", "null"] },
    "hasMore": { "type": "boolean" },
    "query_status": { "type": ["object", "null"] },
    "modifiers": { "type": ["object", "null"] },
    "timings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "k": { "type": "string" },
          "t": { "type": "number" }
        },
        "additionalProperties": true
      }
    },
    "cache_key": { "type": ["string", "null"] },
    "is_cached": { "type": "boolean" },
    "last_refresh": { "type": ["string", "null"] },
    "next_allowed_client_refresh": { "type": ["string", "null"] },
    "timezone": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}
